{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "agent-memory-mcp-duvland",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-16",
	"compatibility_flags": ["nodejs_compat"],

	// R2 bucket for file storage
	"r2_buckets": [
		{
			"binding": "MEMORY_BUCKET",
			"bucket_name": "duvland"
		}
	],

	// Durable Objects for embedding index
	"durable_objects": {
		"bindings": [
			{
				"name": "MEMORY_INDEX",
				"class_name": "MemoryIndex"
			}
		]
	},

	// Workers AI for embeddings
	"ai": {
		"binding": "AI"
	},

	// SQLite storage for Durable Objects
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["MemoryIndex"]
		}
	],

	// Cron triggers for scheduled reflection
	"triggers": {
		"crons": ["0 6 * * *"] // Daily at 6am UTC (London morning)
	},

	// Reflection model configuration
	// duvland: cheaper-by-default models, validated head-to-head against Kimi K2.6 on
	// real reflection content (see PR #11 evaluation, 2026-05-16).
	// - Primary: gemma-4-26b-a4b-it ($0.10/M in, $0.30/M out, 256k ctx, reasoning + tools)
	//   Found the same top-tier issues as Kimi K2.6 at ~22x cheaper.
	// - Fast: glm-4.7-flash ($0.06/M in, $0.40/M out, 131k ctx)
	//   Granite 4 micro was too shallow (3 issues, missed Sentry Zero / COFS / Perplexity);
	//   GLM-4.7-flash gave the broadest coverage of any model tested. Worth the +$0.001/call.
	"vars": {
		"REFLECTION_MODEL": "@cf/google/gemma-4-26b-a4b-it",
		"REFLECTION_MODEL_FAST": "@cf/zai-org/glm-4.7-flash",
		"USE_AGENTIC_REFLECTION": "true"
	}
}
