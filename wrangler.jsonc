{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "agent-memory-mcp-duvland",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-16",
	"compatibility_flags": ["nodejs_compat"],

	// R2 bucket for file storage
	"r2_buckets": [
		{
			"binding": "MEMORY_BUCKET",
			"bucket_name": "duvland"
		}
	],

	// Durable Objects for embedding index
	"durable_objects": {
		"bindings": [
			{
				"name": "MEMORY_INDEX",
				"class_name": "MemoryIndex"
			}
		]
	},

	// Workers AI for embeddings
	"ai": {
		"binding": "AI"
	},

	// SQLite storage for Durable Objects
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["MemoryIndex"]
		}
	],

	// Cron triggers for scheduled reflection
	"triggers": {
		"crons": ["0 6 * * *"] // Daily at 6am UTC (London morning)
	},

	// Reflection model configuration
	// duvland: cheaper-by-default models for the non-CF fork.
	// - Primary: gemma-4-26b-a4b-it ($0.10/M in, $0.30/M out, 256k ctx, reasoning + tools)
	//   vs Kimi K2.6 ($0.95/M in, $4.00/M out) — ~9.5x cheaper input, ~13x cheaper output.
	// - Fast: granite-4.0-h-micro ($0.017/M in, $0.112/M out) — purpose-built for agentic
	//   workflows. ~3.5x cheaper than GLM-4.7-flash, designed for instruction following.
	"vars": {
		"REFLECTION_MODEL": "@cf/google/gemma-4-26b-a4b-it",
		"REFLECTION_MODEL_FAST": "@cf/ibm-granite/granite-4.0-h-micro",
		"USE_AGENTIC_REFLECTION": "true"
	}
}
